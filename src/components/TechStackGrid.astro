---
// Tech-stack category cards (8 groups, no filtering — with one card per
// category a filter just hid the grid). Chips are non-interactive data tags
// with a hover accent; selection/copy is disabled site-wide.
import { techStack } from '../data/tech-stack';
import Icon from './Icon.astro';
---

<div
  class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3"
  data-reveal-group="y"
  data-reveal-stagger="0.07"
>
  {
    techStack.map((group) => (
      <div class="group flex flex-col gap-4 border border-line bg-surface p-5 transition-colors duration-200 hover:border-accent lg:p-6">
        <div class="flex items-center gap-3">
          <span class="flex h-10 w-10 shrink-0 items-center justify-center border border-line bg-surface-raised text-accent transition-colors duration-200 group-hover:border-accent">
            <Icon name={group.icon} size={20} />
          </span>
          <h3 class="font-heading text-lg font-semibold text-text transition-colors duration-200 group-hover:text-text-bright">
            {group.label}
          </h3>
        </div>
        <ul class="flex flex-wrap gap-2">
          {group.items.map((item) => (
            <li class="whitespace-nowrap border border-line bg-surface-raised px-3 py-1.5 font-mono text-sm text-text transition-all duration-150 hover:-translate-y-0.5 hover:border-accent hover:text-accent">
              {item}
            </li>
          ))}
        </ul>
      </div>
    ))
  }
</div>
