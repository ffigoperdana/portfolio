---
// Reusable section heading: h2 (+ optional terminal cursor) with optional
// right-aligned meta line. The h2 carries `{id}-h` so the parent <section>
// can reference it via aria-labelledby.
interface Props {
  id: string;
  title: string;
  cursor?: boolean;
  meta?: string;
}

const { id, title, cursor = false, meta } = Astro.props;
---

<div class="mb-10 flex flex-wrap items-end justify-between gap-x-8 gap-y-3">
  <!-- aria-label keeps the accessible name stable while the visible text is
       typed out by scripts/type-title.ts (skipped without JS / reduced motion) -->
  <h2
    id={`${id}-h`}
    aria-label={title}
    class="text-headline-lg text-text-bright"
  >
    <span data-type-target aria-hidden="true" class="inline-block">{title}</span
    >{cursor && <span class="terminal-cursor" aria-hidden="true" />}
  </h2>
  {
    meta && (
      <p class="max-w-xs font-mono text-sm text-text-muted sm:text-right">
        {meta}
      </p>
    )
  }
</div>
