---
// Hero: text block + hanging identity card. Mobile order = card first
// (strap connects to the header directly above), text below; from lg: the
// text sits left (7 cols) and the two-faced card hangs beside it, slowly
// spinning on its lanyard until grabbed (physics in scripts/lanyard.ts).
import IdentityCard from './IdentityCard.astro';
import IdentityCardBack from './IdentityCardBack.astro';
import { site } from '../data/site';
import portrait from '../assets/portrait.jpg';

const roles = site.roles.map((r) => r.toUpperCase());
const longestRole = roles.reduce((a, b) => (b.length > a.length ? b : a));
---

<section
  aria-label="Introduction"
  class="relative mx-auto max-w-7xl px-4 sm:px-8"
>
  <!-- Dim synthwave horizon at the hero floor (decorative, static) -->
  <div class="horizon" aria-hidden="true"></div>

  <div class="flex flex-col lg:grid lg:grid-cols-12 lg:items-center lg:gap-6">
    <div
      class="hero-content relative z-[1] order-2 flex flex-col items-start gap-6 py-12 lg:order-none lg:col-span-7 lg:py-24 lg:pl-8"
      data-reveal-load
    >
      <p class="font-mono text-sm text-accent">
        INITIATING BOOT SEQUENCE... OK.
      </p>
      <h1 class="text-headline-xl text-text">
        FIGO PERDANA:<br />
        <span class="inline-grid whitespace-nowrap text-text-bright">
          <span class="invisible col-start-1 row-start-1" aria-hidden="true"
            >[{longestRole}]</span
          >
          <span
            class="col-start-1 row-start-1"
            data-role-rotator
            data-roles={JSON.stringify(roles)}
            aria-hidden="true">[{roles[0]}]</span
          >
          <span class="sr-only">{site.roles.join(' · ')}</span>
        </span>
      </h1>
      <p class="max-w-[65ch] font-mono text-text-muted">{site.description}</p>
      <div class="flex flex-wrap gap-3">
        <a
          href="#experience"
          class="text-label flex min-h-11 items-center border border-accent bg-accent px-6 uppercase text-on-accent transition-all duration-200 hover:bg-transparent hover:text-accent hover:crt-glow"
        >
          EXECUTE_LOG
        </a>
        <a
          href="#contact"
          class="text-label flex min-h-11 items-center border border-accent px-6 uppercase text-accent transition-shadow duration-200 hover:crt-glow"
        >
          PING_ME
        </a>
      </div>
    </div>

    <div
      class="order-1 flex justify-center lg:order-none lg:col-span-5 lg:col-start-8 lg:justify-center lg:pb-12"
    >
      <div class="lanyard-scene w-full max-w-[320px]" data-reveal-fade>
        <div class="lanyard-rig" data-lanyard>
          <div class="strap flex flex-col items-center" aria-hidden="true">
            <div class="strap-line"></div>
            <div class="clasp border border-line bg-surface-raised"></div>
          </div>
          <div class="card-swing" data-lanyard-card>
            <div
              class="card-3d relative w-full cursor-grab touch-pan-y select-none active:cursor-grabbing"
              data-lanyard-grab
            >
              <div class="card-face">
                <IdentityCard
                  name="FIGO PERDANA"
                  roleLine="DEVOPS // NETWORK // INFRA"
                  photo={portrait}
                />
              </div>
              <div class="card-face card-back" aria-hidden="true">
                <IdentityCardBack />
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Glowing baseline of the hero's L-frame (meets the vertical line left) -->
  <div class="hero-baseline" aria-hidden="true"></div>
</section>

<style>
  /* Perspective grid fading toward the section floor — opacity tuned to the
     reference demo's BALANCED preset (0.11); purely decorative, no motion. */
  .horizon {
    position: absolute;
    left: 50%;
    bottom: -1px;
    width: 120vw;
    height: 300px;
    transform: translateX(-50%);
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
    mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      rgba(0, 0, 0, 0.28) 18%,
      #000 60%,
      transparent 100%
    );
  }
  .horizon::before {
    content: '';
    position: absolute;
    left: 50%;
    bottom: -180px;
    width: 1180px;
    height: 540px;
    transform: translateX(-50%) perspective(470px) rotateX(67deg);
    transform-origin: center bottom;
    opacity: 0.11;
    background-image:
      linear-gradient(rgba(156, 222, 242, 0.85) 1px, transparent 1px),
      linear-gradient(90deg, rgba(156, 222, 242, 0.85) 1px, transparent 1px);
    background-size: 44px 44px;
  }
  /* The hero's existing L-frame, now softly lit (owner request): a gradient
     vertical line beside the text and a glowing baseline underneath — the
     glow stays faint so nothing competes with content. */
  @media (min-width: 1024px) {
    .hero-content::before {
      content: '';
      position: absolute;
      left: 0;
      top: 1.5rem;
      bottom: 0;
      width: 1px;
      background: linear-gradient(
        180deg,
        transparent,
        rgba(156, 222, 242, 0.45) 15%,
        rgba(156, 222, 242, 0.28) 85%,
        rgba(156, 222, 242, 0.45) 100%
      );
      box-shadow: 0 0 12px rgba(156, 222, 242, 0.3);
    }
  }
  .hero-baseline {
    position: absolute;
    left: 1rem;
    right: 1rem;
    bottom: 0;
    height: 1px;
    background: linear-gradient(
      90deg,
      rgba(156, 222, 242, 0.5),
      rgba(156, 222, 242, 0.18) 55%,
      transparent
    );
    box-shadow: 0 0 10px rgba(156, 222, 242, 0.22);
    pointer-events: none;
  }
  @media (min-width: 640px) {
    .hero-baseline {
      left: 2rem;
      right: 2rem;
    }
  }

  .lanyard-scene {
    perspective: 1200px;
    /* ================================================================
       ATUR POSISI KARTU DI SINI (desktop >=1280px saja):
       nilai POSITIF = geser ke KANAN, NEGATIF = ke KIRI.
       Contoh: 0px = center kolom, 60px = lebih ke kanan, -40px = kiri.
       ================================================================ */
    --card-nudge-x: 0px;
  }
  @media (min-width: 1280px) {
    .lanyard-scene {
      transform: translateX(var(--card-nudge-x));
    }
  }
  .lanyard-rig {
    display: flex;
    flex-direction: column;
    align-items: center;
    transform-origin: 50% 0;
    transform: rotateZ(var(--swing, 0deg));
    transform-style: preserve-3d;
    will-change: transform;
  }
  .strap-line {
    width: 8px;
    height: 4.5rem;
    background: repeating-linear-gradient(
      0deg,
      var(--color-line) 0 6px,
      color-mix(in srgb, var(--color-line) 55%, var(--color-bg)) 6px 12px
    );
  }
  @media (min-width: 1024px) {
    .strap-line {
      height: 3.5rem;
    }
  }
  .clasp {
    width: 22px;
    height: 12px;
    margin-bottom: -2px;
  }
  .card-swing {
    width: 100%;
    transform-origin: 50% -1rem;
    transform: rotateX(var(--wobx, 0deg)) rotateZ(var(--lag, 0deg));
    transform-style: preserve-3d;
    will-change: transform;
  }
  .card-3d {
    transform: rotateY(var(--spin, 0deg));
    transform-style: preserve-3d;
    will-change: transform;
  }
  .card-face {
    backface-visibility: hidden;
  }
  .card-back {
    position: absolute;
    inset: 0;
    transform: rotateY(180deg);
  }
</style>

<script>
  import '../scripts/lanyard';
  import '../scripts/role-rotator';
</script>
