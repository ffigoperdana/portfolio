---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404" description="Route not found.">
  <div
    class="mx-auto flex max-w-7xl flex-col items-start gap-6 px-4 py-24 sm:px-8"
  >
    <p class="font-mono text-sm text-danger">ERR_404: ROUTE_NOT_FOUND</p>
    <h1 class="text-headline-xl text-text-bright">
      SEGMENTATION_FAULT<span class="terminal-cursor" aria-hidden="true"></span>
    </h1>
    <p class="max-w-[65ch] font-mono text-text-muted">
      The requested path does not exist in this filesystem. Check the address or
      return to a known mount point.
    </p>
    <a
      href="/"
      class="text-label flex min-h-11 items-center border border-accent bg-accent px-6 uppercase text-on-accent transition-all duration-200 hover:bg-transparent hover:text-accent hover:crt-glow"
    >
      cd /home
    </a>
  </div>
</BaseLayout>
